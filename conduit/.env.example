# Conduit relay configuration
# Copy this file to .env and adjust values

# Maximum concurrent clients (10-1000)
CONDUIT_MAX_CLIENTS=50

# Bandwidth cap in Mbps
CONDUIT_BANDWIDTH=100

# Grafana dashboard credentials
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme

# Grafana port (change if 3000 is taken)
GRAFANA_PORT=3000
